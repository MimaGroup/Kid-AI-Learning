{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/inactive-users",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/email/welcome",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/engagement/weekly-summary",
      "schedule": "0 9 * * 1"
    }
  ]
}
